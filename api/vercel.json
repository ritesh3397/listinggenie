{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/Index.html" },
    { "src": "/login", "dest": "/Login.html" },
    { "src": "/signup", "dest": "/Login.html" },
    { "src": "/generator", "dest": "/Generater.html" },
    { "src": "/pricing", "dest": "/Pricing.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
